{
  "name": "forge-desktop-framework",
  "private": true,
  "version": "0.1.61",
  "description": "Open source local-engine desktop app framework — Electron + Python Worker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uulab-official/forge-desktop-framework.git"
  },
  "homepage": "https://github.com/uulab-official/forge-desktop-framework",
  "bugs": {
    "url": "https://github.com/uulab-official/forge-desktop-framework/issues"
  },
  "keywords": [
    "electron",
    "python",
    "desktop",
    "framework",
    "pyinstaller",
    "ipc",
    "local-engine",
    "react",
    "tailwindcss",
    "vite"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "scaffold:test": "bash scripts/test-scaffold-builds.sh",
    "scaffold:external:test": "bash scripts/test-external-scaffold.sh",
    "release:checklist:prepare": "bash scripts/create-release-checklist.sh",
    "release:checklist:verify": "bash scripts/verify-release-checklist.sh",
    "release:audit": "pnpm --filter create-forge-desktop build && bash scripts/audit-release-surfaces.sh",
    "release:artifacts:test": "bash scripts/test-release-artifact-audit.sh",
    "release:channels:test": "bash scripts/test-publish-channel-parity.sh",
    "release:recovery:test": "bash scripts/test-release-channel-recovery.sh",
    "release:drill:test": "bash scripts/test-rollback-drill.sh",
    "release:bundle:test": "bash scripts/test-release-inventory-bundle.sh",
    "release:bundle:index:test": "bash scripts/test-release-bundle-index.sh",
    "release:bundle:retrieve:test": "bash scripts/test-release-inventory-retrieval.sh",
    "release:bundle:fetch:test": "bash scripts/test-release-bundle-fetch.sh",
    "release:manifests:test": "bash scripts/test-release-manifest-audit.sh",
    "release:rollback:test": "bash scripts/test-rollback-readiness-audit.sh",
    "release:playbook:test": "bash scripts/test-rollback-playbook.sh",
    "release:signing:test": "bash scripts/test-signing-readiness-audit.sh",
    "release:matrix:test": "bash scripts/test-release-matrix-summary.sh",
    "release:provenance:test": "bash scripts/test-release-provenance.sh",
    "release:bump": "bash scripts/release.sh",
    "release:ship": "bash scripts/ship-release.sh",
    "version:check": "bash scripts/check-versions.sh",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
