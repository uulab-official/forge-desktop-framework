{
  "name": "forge-desktop-framework",
  "private": true,
  "version": "0.1.45",
  "description": "Open source local-engine desktop app framework — Electron + Python Worker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uulab-official/forge-desktop-framework.git"
  },
  "homepage": "https://github.com/uulab-official/forge-desktop-framework",
  "bugs": {
    "url": "https://github.com/uulab-official/forge-desktop-framework/issues"
  },
  "keywords": [
    "electron",
    "python",
    "desktop",
    "framework",
    "pyinstaller",
    "ipc",
    "local-engine",
    "react",
    "tailwindcss",
    "vite"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "scaffold:test": "bash scripts/test-scaffold-builds.sh",
    "scaffold:external:test": "bash scripts/test-external-scaffold.sh",
    "release:audit": "pnpm --filter create-forge-desktop build && bash scripts/audit-release-surfaces.sh",
    "release:bump": "bash scripts/release.sh",
    "release:ship": "bash scripts/ship-release.sh",
    "version:check": "bash scripts/check-versions.sh",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
