{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist-electron",
    "rootDir": ".",
    "lib": [
      "ES2022"
    ],
    "composite": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "electron"
  ]
}
