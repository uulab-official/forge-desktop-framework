{
  "name": "@forge/worker-client",
  "version": "0.1.115",
  "description": "Spawn and communicate with Forge Python workers over stdin/stdout JSON",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@forge/ipc-contract": "workspace:*",
    "@forge/logger": "workspace:*",
    "@forge/resource-manager": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uulab-official/forge-desktop-framework.git",
    "directory": "packages/worker-client"
  },
  "homepage": "https://github.com/uulab-official/forge-desktop-framework",
  "bugs": {
    "url": "https://github.com/uulab-official/forge-desktop-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "forge",
    "python",
    "worker",
    "ipc",
    "desktop"
  ]
}
