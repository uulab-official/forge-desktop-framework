{
  "name": "create-forge-desktop",
  "version": "0.1.107",
  "description": "Create Forge Desktop apps — Electron + Python Worker framework",
  "type": "module",
  "bin": {
    "create-forge-desktop": "dist/create.js",
    "forge-desktop": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "bash ../../scripts/sync-templates.sh",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "keywords": [
    "electron",
    "python",
    "desktop",
    "framework",
    "scaffold",
    "create-app",
    "cli",
    "forge"
  ]
}
